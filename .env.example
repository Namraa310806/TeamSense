# TeamSense environment template
# Copy to .env and update values for your local setup.

# Django
DJANGO_SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (used when USE_POSTGRES=True)
USE_POSTGRES=True
DB_NAME=teamsense
DB_USER=teamsense
DB_PASSWORD=teamsense123
DB_HOST=postgres
DB_PORT=5432

# CORS (optional)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0

# AI providers (optional)
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=
HF_TOKEN=
